function TMain.EditarMySql(Porta, Status, Profile, VelUP, VelDN: String): boolean;
var
   velUP_pt, velDN_pt: String;
   status_pt, analise_st, Info_analise: String;

begin
    if MenuRastrear2.Checked then Rastrear('EditarMySql( ' + Porta + ' )');
	 
    // Seta valor vazio
    velUP_pt :='';
    velDN_pt :='';
    analise_st := '';
    Info_analise := 'Normal';
   // data := Time;


    // Procura registro, aponta para -> Porta
    ZTbPtLucent.Locate('obj_porta',Porta,[]);

    // Comparar Status
    if ( Status = 'Sincronizada') or (Status = 'Năo sync') then status_pt := 'Ativa';
    if ( Status = 'Bloqueda' ) then status_pt := 'Ativa';

    if ( DbEdStatus.Text = 'Ativa') and (status_pt <> 'Ativa' ) then begin
        analise_st := 'Status irregular';
        Info_analise := 'Irregular';
    end;

    if ( DbEdStatus.Text <> 'Ativa') and (status_pt = 'Ativa' ) then begin
        analise_st := 'Status irregular';
        Info_analise := 'Irregular';
    end;

    if ( DdEdVelUP.Text <> VelUP ) then begin
        velUP_pt :='Vel.Up Irregular';
        Info_analise := 'Irregular';
    end;

    if ( DbEdVelDN.Text <> VelDN ) then begin
        velUP_pt :='Vel.Dn Irregular';
        Info_analise := 'Irregular';
    end;


    // Este código edita o registro que foi localizado acima
       ZTbPtLucent.Edit;
       ZTbPtLucent.FieldByName('egd_status').Value := Status;
       ZTbPtLucent.FieldByName('egd_profile').Value := Profile;
       ZTbPtLucent.FieldByName('egd_vel_up').Value := VelUP;
       ZTbPtLucent.FieldByName('egd_vel_dn').Value := VelDN;
       ZTbPtLucent.FieldByName('egd_analise').Value := Info_analise;
       ZTbPtLucent.FieldByName('egd_acao').Value := 'Monitorada';
       ZTbPtLucent.FieldByName('egd_obs').Value := analise_st +', ' + velUP_pt +', ' + velDN_pt;
       ZTbPtLucent.FieldByName('egd_data').Value := DateTimeToStr(Now);
       ZTbPtLucent.UpdateRecord;
       ZTbPtLucent.next;

       result := true;

end;

