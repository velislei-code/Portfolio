function TMain.ContarPlacas: Integer;
var
   Shelf, SS: Integer;
begin

  //Contar ocorrencia de uma palavra(unknown) em um Memo
  Shelf := 16;                                          // 14 placas IUADSL72 + 2 CTRL(CXM)
  for SS := 1 to length(resposta) do begin
        if copy(resposta,SS,length('unknown')) = 'unknown' then
        Dec(Shelf);
  end;
  if MenuRastrear2.Checked then Rastrear('ContarPlacas(): [' + IntToStr(Shelf) + ']');

  

  result := Shelf;

end;

