function TMain.ShState(Versao: String): string;
var
   PTstatus: String;
   SS, QtosUP, QtosUP_DN: Integer;

begin
   QtosUP := 0;
   QtosUP_DN := 0;

  // Contar ocorrencia de uma palavra em uma String/Memo
  // Se 5 vezes: se refere ao menu
  // Se 6 vezes: 5 săo do menu e 1 é do status da porta

  //***************************************************
  // UP/ UP
  for SS := 1 to length(resposta) do begin
        if copy(resposta,SS,length('UP/')) = 'UP/' then
        Inc(QtosUP);
  end;
  if QtosUP = 6 then PTstatus := 'Sincronizada';

  //***************************************************
  // UP/DOWN
  for SS := 1 to length(resposta) do begin
        if copy(resposta,SS,length('UP/DOWN')) = 'UP/DOWN' then
        Inc(QtosUP_DN);
  end;
  if QtosUP_DN = 6 then PTstatus := 'Năo sincroni';

  //***************************************************
  // Procura por: DOWN/DOWN
  if pos('DOWN/DOWN', resposta)>0 then PTstatus := 'Bloqueada';

  //***************************************************  
  if MenuRastrear2.Checked then Rastrear('ShState( ' + PTstatus + ' )'); 
   result := PTstatus;
   
end;

