....................    Calculos 
....................       ---------------------------------------------------------   
....................       Divisor de tensăo 
....................          R1 = [ (R2 / Vo).Vi ] - R2 
....................          Vo = +5Vcc 
....................          Vi = +48Vcc 
....................           
....................          R1 ao +Vcc 
....................          Centro - saída da mediçăo 
....................          R2 ao GND 
....................       ---------------------------------------------------------     
....................       Freq. do PWM 
....................           
....................          setup_timer_2(T2_DIV_BY_1, 255, 16);   // = 3906,3 Hz - (..,16) năo muda 
....................        
....................          Freq = { 1[ (PR2+1).4.(1/Clock) ] } / T2_DIV_BY 
....................              
....................             PR2(1a255) 
....................             Clock(do osc do PIC - 4Mhz) 
....................             T2_DIV_BY(1, 4 ou 16) 
....................     
.................... */ 
