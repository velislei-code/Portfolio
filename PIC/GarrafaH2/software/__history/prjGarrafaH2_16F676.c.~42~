int iHabExecPoloNP = Sim;   // Ctrl exec.da funcao somente 1 vez p/ ciclo, p/ evitar inversoes continuas
int iHabExecPoloPN = Sim;   // Ctrl exec.da funcao somente 1 vez p/ ciclo, p/ evitar inversoes continuas
