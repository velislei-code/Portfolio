void inicializar(){

      iDecSeg = 0;
      iSeg = 0;
      iMin = 0;
      
      iCircuito = Off;       // Ctrl estado atual do circuito: On(1)/Off(0)
      iBtnPress = Nao;         // Ctrl o pressionamento do Btn On/Off
      iStartCiclo = Nao;     // Ctrl/limita somente 1 start em ciclo p/ evitar descontrole
      iTempo = 5;
      iHabExecPoloNP = Sim;   // Ctrl exec.da funcao somente 1 vez p/ ciclo, p/ evitar inversoes continuas
      iHabExecPoloPN = Sim;   // Ctrl exec.da funcao somente 1 vez p/ ciclo, p/ evitar inversoes continuas
     // cMsg = '!';
      iModoEspera = Nao;    // Ctrl aviso discreto de p/ evitar esquecer - após H2 finalizado
     
}

void Clock_PIC(){
// Faz ctrl de seg, min, hr
       
      if(iDecSeg > 9){
         iDecSeg = 0;
         iSeg++;
         if(iGerandoH2 == Sim){ piscaLed(1, 500, LED_AZ); }   
         //if( (input(PIN_TimeD) == Sim)){ piscaLed(1, 500, LED_VD);  piscaLed(1, 500, LED_VM);}   // teste saida C
      }
      
      if(iSeg > 59){
         iDecSeg = 0;
         iSeg = 0;
         iMin++;
      }
      
      if(iMin > 59){
         iDecSeg = 0;
         iSeg = 0;
         iMin = 0;        
         
      }
      
      // INicio de tratamento de processos
      if(iCircuito == On){
         
         if(iSeg < iTempo){
             PoloPN();   
             delay_ms(10);
             break;  
               
         }
         else if( (iSeg > iTempo)&&(iSeg < iTempo*2) ){ 
         
             PoloNP();  
             delay_ms(10);
             break;    
         }
         else if( (iSeg > iTempo*2)&&(iSeg < iTempo*3) ){ 
         
             buzzer(3, 100);            // Aciona Buzzer(3beep de 100ms), aviso de finalizacao
             Stop();
             iModoEspera = Sim;         // H2 finalizado, Habilita aviso anti-esquecimento
             zerarClock();
             break;
         }
         else if(iSeg > iTempo*3){ 
         
            Stop();
             break;   
        }
         
      }else{
          Stop();
          break;      
      }
      
      // Caso H2 tenha finalizado...aciona aviso de modo espera
      if( (iModoEspera == Sim)&&(iCircuito == Off)){
         if(iSeg > iTempo){    
            buzzer(2, 50);       // aciona buzzer (1beep de 50ms)
            zerarClock();
         }
      }
      
  
      iDecSeg++;  // Incrementa DecSegundos
      
}

void zerarClock(){

      iDecSeg = 0;
      iSeg = 0;
      iMin = 0; 
}


void PoloPN(){

      if(iHabExecPoloPN == Sim){  // Condicao evita exec.varias vezes no mesmo ciclo, o q estava causanso inversăo continua
      
        output_high(PIN_LED_AZ);     // Led Azul (H2 acionado)   
        output_low(PIN_PteHx);      // Polos (+/-)
        output_high(PIN_PteHy);  
        iHabExecPoloPN = Nao;     // Como ja exec.neste ciclo, bloqueia nova exec.
        
     //   printf(lcd_putc,"\f %d:%d:%d - Pn \n\r On: %d", iMin, iSeg, iDecSeg, iCircuito);        // L? a entrada da porta analogica(Volt()) e imprimir no lcd (\f limpa o lcd)
       // cMsg = 'P';
        delay_ms(50);
      }
}

void PoloNP(){

    if(iHabExecPoloNP == Sim){    // Condicao evita exec.varias vezes no mesmo ciclo, o q estava causanso inversăo continua
        output_high(PIN_LED_AZ);     // Led Azul (H2 acionado)   
        output_high(PIN_PteHx);     // Polos (-/+)
        output_low(PIN_PteHy);  
        iHabExecPoloNP = Nao;     // Como ja exec.neste ciclo, bloqueia nova exec.
        
     //   printf(lcd_putc,"\f %d:%d:%d - Np \n\r On: %d", iMin, iSeg, iDecSeg, iCircuito);        // L? a entrada da porta analogica(Volt()) e imprimir no lcd (\f limpa o lcd)
       // cMsg = 'N';
        delay_ms(50);
    }
}

void Aterrar(){
      
     output_high(PIN_PteHx);     // 2 eletrodos ao Negativo (-/-)
     output_high(PIN_PteHy);  
     iHabExecPoloNP = Sim;     // Habilita Exec.da funcao
     iHabExecPoloPN = Sim;
     
    // printf(lcd_putc,"\f %d:%d:%d - ATR \n\r On: %d", iMin, iSeg, iDecSeg, iCircuito);        // L? a entrada da porta analogica(Volt()) e imprimir no lcd (\f limpa o lcd)
     //cMsg = 'A';
     delay_ms(50);
}

void Start(){
   
     output_high(PIN_LED_AZ);    // Led Azul (H2 acionado)  
     //output_high(PIN_LED_VD);    // Led Verde - tst (H2 acionado)  
     
     PoloPN();  
     iGerandoH2 = Sim;         // Habilita Piscar-Led durante geracao H2
        
     if(iStartCiclo == Sim){        // Condicao evita que exec.continuamente - assim exec.somente 1x
         
         iStartCiclo = Nao;         // Bloqueia novo start p/ este ciclo
         iDecSeg = 0;
         iSeg = 0;
         iMin = 0;
      }
     
}

void Stop(){

     
      Aterrar();
      iGerandoH2 = Nao;             // Desabilita Piscar-Led durante geracao H2 
      iCircuito = Off;
      
       if(iStartCiclo == Nao){      // Condicao evita que exec.continuamente - assim exec.somente 1x
            iStartCiclo = Sim;      // Libera novo start p/ este ciclo
       }
      if(iModoEspera == Sim){         
          output_high(PIN_LED_AZ);
      }else{
          output_low(PIN_LED_AZ);   // Led Azul (H2 desligado)  
      }
      // output_low(PIN_LED_VD);      // Led verde-teste (H2 acionado)  
     
}


void buzzer(int iN, int iT){
 // Ativa Buzzzer - Avisa finalizacao dos ciclos com 3 Bips
      for(int bz=0; bz<iN; bz++){
         output_high(PIN_BUZZER);    // Buzzer (H2 acionado)
         delay_ms(iT);
         output_low(PIN_BUZZER);    // Buzzer (H2 acionado)
         delay_ms(iT);
      }

}

void piscaLED(int iN, int iT, int iQual){
// Pisca Led durante Geraracao de H2
      for(int p=0; p<iN; p++){
         if(iQual == LED_AZ){ output_high(PIN_LED_AZ);   }
         else if(iQual == LED_VD){ output_high(PIN_LED_VD);  }
         else if(iQual == LED_VM){ output_high(PIN_LED_VM);  }
         else{ output_high(PIN_LED_AZ);   }
         delay_ms(iT);
         if(iQual == LED_AZ){ output_low(PIN_LED_AZ);   }
         else if(iQual == LED_VD){ output_low(PIN_LED_VD);  }
         else if(iQual == LED_VM){ output_low(PIN_LED_VM);  }
         else{ output_low(PIN_LED_AZ);   }
         delay_ms(iT);
      }
}

void checkPressBtn(int iT){
// Cria histerese no botao p/ acionar circuito

   if(input(PIN_BTN) == BtnPress){
      if(iTimePressBtn >= iT){
         
      
            // caso Circuito esteja em modo espera(H2 pronto), o pressionar do botăo somente tira de modo espera, 1 segundo pressionar vai ligar o circuito
           if(iModoEspera == Sim){  
               iModoEspera = Nao;      // Tira de modo espera
               buzzer(2, 50);          // Avisa que recebeu cmd
           }else{
             /*
               FALHA!...esta entrando direto aqui
             */  
               if(iCircuito == On){ iCircuito = Off; }
               else if(iCircuito == Off){ iCircuito = On; }
               buzzer(1,50);              // Bip de teclado      
               
           }
            iTimePressBtn=0;
            
      }
      iTimePressBtn++;
   
   }else{
      iBtnPress == Nao;
      iTimePressBtn=0;
   }




}

void checkBordaUpBtn(){
   // Verifica se botao foi solto(presenca de borda de subida)
   
      int iBorda = Nula;
   
      if( (iBtnPress == Nao)&&(input(PIN_BTN) == 0) ){  iBorda = Nula; iBtnPress = 0;}
      else if( (iBtnPress == Nao)&&(input(PIN_BTN) == 1) ){ iBorda = Down; iBtnPress = 1; }
      else if( (iBtnPress == Sim)&&(input(PIN_BTN) == 0) ){ iBorda = Up; iBtnPress = 0; }          // Detectado Borda de subida aqui
      else if( (iBtnPress == Sim)&&(input(PIN_BTN) == 1) ){ iBorda = Down;  iBtnPress = 1;}
      else{ iBorda = Nula; iBtnPress = 0; }
      
      
      if( iBorda == Up ){   
      
              // buzzer(10,500);              // entrei aqui Bip de teclado
       
               if(iCircuito == On){ 
                  if(iPosBtn == 0){ 
                     output_high(PIN_LED_VD);
                     output_low(PIN_LED_VM);
                     iAcrecimo50 = Sim;     // Acrecimo de 50% na eletrolise
                     iHabCtrlH2 = Nao;      // Ctrl o H2, refazendo eletrolise a cada X Horas       
                     break;
                  }else if(iPosBtn == 1){ 
                     output_high(PIN_LED_VD);
                     output_high(PIN_LED_VM);
                     iAcrecimo50 = Sim;     // Acrecimo de 50% na eletrolise
                     iHabCtrlH2 = Sim;      // Ctrl o H2, refazendo eletrolise a cada X Horas       
                     break;
                  }else if(iPosBtn == 2){ 
                     output_low(PIN_LED_VD);
                     output_high(PIN_LED_VM);
                     iAcrecimo50 = Nao;     // Acrecimo de 50% na eletrolise
                     iHabCtrlH2 = Sim;      // Ctrl o H2, refazendo eletrolise a cada X Horas       
                     break;
                  }else if(iPosBtn == 3){ 
                     output_low(PIN_LED_VD);
                     output_low(PIN_LED_VM);
                     iAcrecimo50 = Nao;     // Acrecimo de 50% na eletrolise
                     iHabCtrlH2 = Nao;      // Ctrl o H2, refazendo eletrolise a cada X Horas       
                     break;
                  }else{ 
                     output_low(PIN_LED_VD);
                     output_low(PIN_LED_VM);
                     iAcrecimo50 = Nao;     // Acrecimo de 50% na eletrolise
                     iHabCtrlH2 = Nao;      // Ctrl o H2, refazendo eletrolise a cada X Horas       
                     break;
                  }
                  iPosBtn++;
                  if(iPosBtn >3){ iPosBtn = 0; }
                  buzzer(1,500);              // Bip de teclado
                   
               }else{
                     output_low(PIN_LED_VD);
                     output_low(PIN_LED_VM);
                     iAcrecimo50 = Nao;     // Acrecimo de 50% na eletrolise
                     iHabCtrlH2 = Nao;      // Ctrl o H2, refazendo eletrolise a cada X Horas       
                     break;
                  }
              
         
      }
       
     
}

