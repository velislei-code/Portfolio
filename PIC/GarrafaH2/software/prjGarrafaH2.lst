.................... void buzzer(int iN, int iT){ 
....................  // Ativa Buzzzer - Avisa finalizacao dos ciclos com 3 Bips 
....................       for(int bz=0; bz<iN; bz++){ 
*
0070:  CLRF   36
0071:  MOVF   34,W
0072:  SUBWF  36,W
0073:  BTFSC  03.0
0074:  GOTO   087
....................          output_high(pin_A1);    // Led Azul (H2 acionado) 
0075:  MOVLB  01
0076:  BCF    0C.1
0077:  MOVLB  02
0078:  BSF    0C.1
....................          delay_ms(iT); 
0079:  MOVLB  00
007A:  MOVF   35,W
007B:  MOVWF  37
007C:  CALL   021
....................          output_low(pin_A1);    // Led Azul (H2 acionado) 
007D:  MOVLB  01
007E:  BCF    0C.1
007F:  MOVLB  02
0080:  BCF    0C.1
....................          delay_ms(iT); 
0081:  MOVLB  00
0082:  MOVF   35,W
0083:  MOVWF  37
0084:  CALL   021
0085:  INCF   36,F
0086:  GOTO   071
....................       } 
0087:  RETURN
....................  
.................... } 
