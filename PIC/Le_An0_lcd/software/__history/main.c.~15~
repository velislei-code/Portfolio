#include <main.h>

#include <lcd.c>

int16 analogico;     // var para pegar 10bits(0-1023) da entrada analogica
int16 Volts();

void main()
{
   setup_adc_ports(sAN0);
   setup_adc(ADC_CLOCK_INTERNAL);

   lcd_init();
   
    printf(lcd_putc,"\f Voltimetro PIC");       // imprimir no lcd (\f limpa o lcd)
    delay_ms(50);     // atualizaçăo de tela a cada X ms
    

   while(TRUE)
   {
     char str[9] = "00000000"; // valor inicial da string 8 zeros
     
      set_adc_channel(0);           // Config qual entrada analogica sera lida
      delay_us(10);                 // tempo para seleçăo
      //analogico = read_adc();       // leitura da entrada analogica
      
      delay_ms(100);                // atualizaçăo de lcd 
      
     // sprintf (str, "% lu", analogico); // resultado "2008"
     
      
      printf(lcd_putc,"\f %lu \n \r",volts());       // imprimir no lcd (\f limpa o lcd)
      delay_ms(50);     // atualizaçăo de tela a cada X ms
    
      
   }

}

 int16 volts() {
      //store = average_volt();          // Recebe o valor médio da tensăo retornando pela funçăo average_volt
      
      analogico = read_adc();       // leitura da entrada analogica
      int16 t_Volts = (analogico*400)/1023;      // 400 = 40.0 Volt(tensăo máx, com 1 decimal) - Converte valor para Volts(1023 Resoluçăo de 10 bits do conversor AD) 
   
      /* caso se tenha um Voltímetro até 60V:
       * Reprojetar o divisor de tensăo p/ 60V
       * Alterar calc para:
       * t_Volts = (store*600)/1023;      
       */
   
      return(t_Volts);
      
   }
