// -- Decla variáveis ---
int16 analogico;                // Var para pegar 10bits(0-1023) da entrada analogica(AN0)-leitura de tensăo de saída
long memVolt;                   // Armazena média de 100 leituras de tensăo
long t_Volts;                   // Armazena tensăo em Volts


unsigned int16 duty1 = 511;     // Inicia duty no meio(0 a 1023)


// --- Declara funçőes ---
int16 Volts();
long medias_volt(); 


void main()
{

   // Setup PWM
   setup_oscillator(OSC_1MHZ);           // Set internal oscillator to 8MHz
   setup_adc(ADC_CLOCK_DIV_8);           // Set ADC conversion time to 8Tosc
  // setup_adc_ports(AN0_TO_AN1);        // Configure AN0 and AN1 as analog inputs
   setup_adc_ports(sAN0);                // Configure AN0 as analog inputs
   
   setup_ccp1(CCP_PWM);                   // Configure CCP1 as a PWM
   //setup_ccp2(CCP_PWM);                 // Configure CCP2 as a PWM
   
   /*
      Temos que usar o Timer2 para configurar a frequęncia pwm
      Use a seguinte equaçăo para calcular a frequęncia pwm:
      Período PWM = [(PR2) + 1] • 4 • Tosc • (Valor de pré-escala TMR2)
      Onde a frequęncia PWM é definida como 1 / [período PWM].
      PR2 é o valor de pré-carga do Timer2,
      Tosc = 1 / (MCU_frequency) O valor de pré-escala TMR2
      pode ser 1, 4 ou 16.
   
      PWM = (PR2+1).4.(1/CLOCK) -> Clock $Mhz, depende da config no Proj.Wizard
      Freq = 1/PWM   
      
      PWM = (250+1).4.(1/4.000.000)
      PWM = 1004.0,000.000.25
      PWM = 0,000.251
      
      Freq = 1/PWM
      Freq = 1/0,000.251
      Freq = 3.984hz
      
      Osc(hz) = Freq / BY_X
      Osc(hz) = 3984/16
      Osc(hz) = 249hz     
      
      BY_1, 4 ou 16, 1a255, 16 
      setup_timer_2(T2_DIV_BY_1, 255, 16);    = 4khz      (16x250=4000 -> 4khz/By_1 = 4khz)
      setup_timer_2(T2_DIV_BY_4, 250, 16);   = 1khz      (16x250=4000 -> 4khz/By_4 = 1khz)
      setup_timer_2(T2_DIV_BY_16, 250, 16);   = 250hz    (16x250=4000 -> 4khz/By_16 = 250hz)
    */
   
   setup_timer_2(T2_DIV_BY_4, 255, 16);    // Set PWM frequency to 244Hz - 
   delay_ms(10);                             // Wait 100ms

   setup_adc_ports(sAN1);                 // Config porta AN1(analogica) leitura de tensăo
   setup_adc(ADC_CLOCK_INTERNAL);

  

    lcd_init();
   
    printf(lcd_putc,"\f Voltimetro PIC");       // imprimir no lcd (\f limpa o lcd)
    delay_ms(50);     // atualizaçăo de tela a cada X ms
    

   while(TRUE)
   {
   
      
      // PWM
      set_adc_channel(0);                   // Select channel AN0
      delay_ms(10);                         // Wait 1ms
      
      
      // Le potenciometro ajustavel
      //duty1 = read_adc();                   // Read from AN0 and store in i - AN0 varia de 0 a 1023
      
      // Alto ajuste Duty(largura de pulso) cfe tensăo de saida(12V)
      if(Volts()>14) duty1-=10;
      else if(Volts()<12) duty1+=10;
      
      if(duty1<1) duty1=1;
      if(duty1>1023) duty1=1023;
      
      delay_ms(10);                         // Wait 1ms
      set_pwm1_duty(duty1);                 // Set pwm1 duty cycle to i
      delay_ms(10);                         // Wait 1ms
      
      //set_adc_channel(1);                  // Select channel AN1
      //delay_ms(1);                         // Wait 1ms
     // j = read_adc();                      // Read from AN1 and store in j
      //set_pwm1_duty(i);                    // Set pwm1 duty cycle to i
      // set_pwm2_duty(j);                    // Set pwm2 duty cycle to j - năo uso porta 2
      //delay_ms(1);                         // Wait 1ms
  
      char cTensao[20] = "i00.0";
      char cDuty1[20] = "i000";
      
      // Leitura da porta analogica
      set_adc_channel(1);           // Config entrada analogica 1 que sera lida(entrada 0 esta potenciometro ajuste largura de pulso PWM)
      delay_us(10);                 // tempo para seleçăo
      //analogico = read_adc();     // leitura da entrada analogica     
    
      printf(lcd_putc,"\f %lu Vcc \n \r",volts());        // Lę a entrada da porta analogica(Volt()) e imprimir no lcd (\f limpa o lcd)
      delay_ms(500);
      printf(lcd_putc,"\f duty %lu \n \r",duty1);        // Lę a entrada da porta analogica(Volt()) e imprimir no lcd (\f limpa o lcd)
      delay_ms(500);                                         // atualizaçăo de tela a cada X ms
   
   
   }

}

int16 volts() {

   memVolt = medias_volt();          // Recebe o valor médio da tensăo retornando pela funçăo average_volt
  // memVolt = read_adc();                    // leitura da entrada analogica
   int16 t_Volts = (memVolt*48)/1023;      // 400 = 40.0 Volt(tensăo máx, com 1 decimal) - Converte valor para Volts(1023 Resoluçăo de 10 bits do conversor AD)
   
   /* caso se tenha um Voltímetro até 60V:
    * Reprojetar o divisor de tensăo p/ 60V
    * Alterar calc para:
    * t_Volts = (store*600)/1023;      
    */
   
   return(t_Volts);

}
   
long medias_volt(){                 // Funçăo que calcula a média de 100 leituras de tensăo
                                    // garante maior precisăo na medida, se houver alma leitura erronea por ruídos, ele vai corrigir pois retorna a média(100) das leituras
   unsigned char i;                 // Var de iteraçőes
   long volt_armazena = 0;          // var local p/ armazenar o valor de tensăo
   
   for(i=0; i<100; i++){                 // Soma as 100 leituras
      //volt_armazena += ADC_Read(0);    // Temp_store = temp_store + ADC_Read(0) (Faz soma das 100 leitiras)
      volt_armazena += read_adc();       // leitura da entrada analogica
   }
   
   return(volt_armazena/100);          // Retorna a media das iteraçőes 
   
   
} // end average_temp

