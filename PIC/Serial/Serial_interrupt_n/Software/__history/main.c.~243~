void fixarBUS(int iBus){
// Ctrl BUS de TX/RX, Local ou Remoto  

    if(iBus == defBusLocal){ 
        output_low(pin_B6);      // Pin(RB6) em Low habilita(Conecta) 74LS244 p/ conexăo com Barramento - TX-Local Transmite
        output_high(pin_B7);     // Pin(RB7) em high Desabilita(Abre) 74LS244 p/ conexăo com Barramento - Abre-Bus TX Remoto
        bBusLocalAtivo = true;
    }else if(iBus == defBusRem){ 
        output_high(pin_B6);    // Pin(RB6) em high Desabilita(Abre) 74LS244 p/ conexăo com Barramento - Abre-Bus TX Local
        output_low(pin_B7);     // Pin(RB7) em Low habilita(Conecta) 74LS244 p/ conexăo com Barramento - TX-Remoto Transmite
        bBusLocalAtivo = false;
    }else{
        output_low(pin_B6);      // Pin(RB6) em Low habilita(Conecta) 74LS244 p/ conexăo com Barramento - TX-Local Transmite
        output_high(pin_B7);     // Pin(RB7) em high Desabilita(Abre) 74LS244 p/ conexăo com Barramento - Abre-Bus TX Remoto
        
        bBusLocalAtivo = true;
    }


}

